# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=practice_hub
# 连接池（云数据库建议 idle 30s 内回收，减少 ECONNRESET）
# DB_CONNECTION_LIMIT=10
# DB_MAX_IDLE=5
# DB_IDLE_TIMEOUT=30000

# JWT 配置
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
JWT_EXPIRE=7d

# 微信小程序配置
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# 微信虚拟支付（代币模式 short_series_coin + currency_pay）
# AppKey 可在小程序后台「虚拟支付 - 基本配置」查看
AppKey=your_virtual_payment_app_key
WECHAT_VIRTUAL_PAY_OFFER_ID=your_virtual_payment_offer_id
# 0=正式环境，1=沙箱环境
WECHAT_VIRTUAL_PAY_ENV=0
# 微信官方代币比例（与小程序后台一致，默认 1 元 = 1 代币；课程/套餐售价须为整数元）
# WECHAT_COIN_PER_YUAN=1
# 充值后轮询 query_order / query_user_balance 次数与间隔
# WECHAT_COIN_RECHARGE_QUERY_ATTEMPTS=5
# WECHAT_COIN_RECHARGE_QUERY_INTERVAL_MS=1500
# 微信虚拟支付消息推送地址（小程序后台配置）：https://你的域名/api/app/wechat/xpay/notify

# 微信支付开放接口服务配置
WECHAT_PAY_MCH_ID=1111726570
WECHAT_PAY_CLOUDRUN_ENV_ID=prod-d1gguk4ie589126ba
WECHAT_PAY_CALLBACK_SERVICE=prod
WECHAT_PAY_CALLBACK_PATH=/api/app/order/pay/notify
# 可选：不配置时默认 127.0.0.1
WECHAT_PAY_SPBILL_CREATE_IP=127.0.0.1

# 腾讯云 COS 配置（用于图片上传）
# 微信云托管对象存储配置
# 注意：使用微信云托管时，不需要配置 SecretId 和 SecretKey
# 系统会自动通过 http://api.weixin.qq.com/_/cos/getauth 获取临时密钥
COS_BUCKET=7072-prod-6g7tpqs40c5a758b-1392943725
COS_REGION=ap-shanghai

# 课程文件直传 COS 时获取上传链接用（微信云托管一般自动注入 CBR_ENV_ID，本地可填 TCB_ENV_ID）
# CBR_ENV_ID=prod-6g7tpqs40c5a758b
# TCB_ENV_ID=prod-6g7tpqs40c5a758b
# 获取直传凭证模式：auto=优先云托管内网接口，失败后公网兜底；public=直接使用公网 tcb/uploadfile + access_token
# 若线上日志出现 85107 URL 不在白名单内，建议设置为 public，或到云托管控制台配置微信令牌白名单 /_/tcb/uploadfile
WECHAT_TCB_UPLOAD_MODE=auto

# 服务器配置
PORT=3333
NODE_ENV=development

# 考研倒计时日期（可选，也可通过管理后台设置）
COUNTDOWN_DATE=2024-12-23

# 小程序版本校验（发布新版本后提高 MINIAPP_MIN_VERSION，旧版本用户会被提示重新进入）
# MINIAPP_MIN_VERSION=1.0.1
# MINIAPP_LATEST_VERSION=1.0.1
