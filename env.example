# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=practice_hub
# 连接池（云数据库建议 idle 30s 内回收，减少 ECONNRESET）
# DB_CONNECTION_LIMIT=10
# DB_MAX_IDLE=5
# DB_IDLE_TIMEOUT=30000

# JWT 配置
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production
JWT_EXPIRE=7d

# 微信小程序配置
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# 微信虚拟支付配置
# AppKey 可在小程序后台「虚拟支付 - 基本配置 - 基础配置」查看
AppKey=your_virtual_payment_app_key
WECHAT_VIRTUAL_PAY_OFFER_ID=your_virtual_payment_offer_id
# productId 必须是在微信虚拟支付后台已发布的商品ID，否则会报 PRODUCT_ID_NOT_PUBLISH。
# 未配置时默认使用 course_课程ID / activation_code_课程ID。
# 推荐 npm run xpay:goods:remote 走 xpay 接口上传（数据库价格为元，接口 upload_item.price 为分=元×100）。
# Excel 批量导入的「道具价格」才是元整数，与接口单位不同，易填错。
# WECHAT_VIRTUAL_PAY_PRODUCT_ID=your_published_virtual_payment_product_id
# 如课程购买和激活码购买使用不同商品，可分别配置以下两项
# WECHAT_VIRTUAL_PAY_COURSE_PRODUCT_ID=your_course_product_id
# WECHAT_VIRTUAL_PAY_ACTIVATION_PRODUCT_ID=your_activation_code_product_id
# 代币充值道具 ID（购课/套餐走先充值代币再扣款，默认 coin_recharge）
# WECHAT_VIRTUAL_PAY_COIN_PRODUCT_ID=coin_recharge
# 1 元人民币兑换代币数量，默认 1
# COIN_PER_YUAN=1
# 后台保存付费课程时自动上传/发布虚拟支付道具（不在用户点击购买时创建）
WECHAT_VIRTUAL_PAY_AUTO_UPLOAD_GOODS=true
# 每日凌晨 4 点自动全量同步课程与套餐虚拟道具价格（需 AUTO_UPLOAD_GOODS=true）
WECHAT_VIRTUAL_PAY_SCHEDULED_SYNC=true
# 批量同步时每个道具之间的间隔毫秒，避免触发微信限流
# WECHAT_VIRTUAL_PAY_BATCH_SYNC_DELAY_MS=300
# 已发布商品 ID（逗号分隔，* 表示全部跳过上传同步），如 course_187
# WECHAT_VIRTUAL_PAY_PRE_PUBLISHED_IDS=course_187
# WECHAT_VIRTUAL_PAY_GOODS_QUERY_ATTEMPTS=3
# WECHAT_VIRTUAL_PAY_GOODS_QUERY_INTERVAL_MS=2000
# 道具上传/发布后，微信侧约需 10 分钟才可 requestVirtualPayment（COIN_OR_PRODUCT_ID_CREATED_IN_RECENTLY）
# WECHAT_VIRTUAL_PAY_GOODS_COOLDOWN_MINUTES=10
# 获取微信 access_token 失败时的重试次数（502/网络抖动，默认 5）
# WECHAT_ACCESS_TOKEN_RETRY=5
# 须为 200×200、小于 200KB，且 URL 路径含 virtual-pay-goods-cover（勿用课程封面）
WECHAT_VIRTUAL_PAY_DEFAULT_ITEM_URL=https://your-bucket.tcb.qcloud.la/images/virtual-pay-goods-cover.png
# 云托管公网域名（不含 /api），用于内置商品图与 TCB 图片代理，例如 https://xxx.sh.run.tcloudbase.com
# WECHAT_CLOUDRUN_PUBLIC_URL=https://xxx.sh.run.tcloudbase.com
# 0=正式环境，1=沙箱环境
WECHAT_VIRTUAL_PAY_ENV=0
WECHAT_VIRTUAL_PAY_MODE=short_series_goods

# 微信支付开放接口服务配置
WECHAT_PAY_MCH_ID=1111726570
WECHAT_PAY_CLOUDRUN_ENV_ID=prod-d1gguk4ie589126ba
WECHAT_PAY_CALLBACK_SERVICE=prod
WECHAT_PAY_CALLBACK_PATH=/api/app/order/pay/notify
# 可选：不配置时默认 127.0.0.1
WECHAT_PAY_SPBILL_CREATE_IP=127.0.0.1

# 腾讯云 COS 配置（用于图片上传）
# 微信云托管对象存储配置
# 注意：使用微信云托管时，不需要配置 SecretId 和 SecretKey
# 系统会自动通过 http://api.weixin.qq.com/_/cos/getauth 获取临时密钥
COS_BUCKET=7072-prod-6g7tpqs40c5a758b-1392943725
COS_REGION=ap-shanghai

# 课程文件直传 COS 时获取上传链接用（微信云托管一般自动注入 CBR_ENV_ID，本地可填 TCB_ENV_ID）
# CBR_ENV_ID=prod-6g7tpqs40c5a758b
# TCB_ENV_ID=prod-6g7tpqs40c5a758b
# 获取直传凭证模式：auto=优先云托管内网接口，失败后公网兜底；public=直接使用公网 tcb/uploadfile + access_token
# 若线上日志出现 85107 URL 不在白名单内，建议设置为 public，或到云托管控制台配置微信令牌白名单 /_/tcb/uploadfile
WECHAT_TCB_UPLOAD_MODE=auto

# 服务器配置
PORT=3333
NODE_ENV=development

# 考研倒计时日期（可选，也可通过管理后台设置）
COUNTDOWN_DATE=2024-12-23
